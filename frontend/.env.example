# Copy this file to .env.local and fill in values from the Firebase Console:
# Project settings → Your apps → Web app → Firebase SDK snippet (config object)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if you use Google Analytics in Firebase
# VITE_FIREBASE_MEASUREMENT_ID=

# FastAPI backend (production on Render)
VITE_API_URL=https://ai-interview-preparation-platform-9p5u.onrender.com

# Local backend override (optional)
# VITE_API_URL=http://localhost:8000
