# --- Option B (recommended): CrewAI AMP cloud crew ---
# From app.crewai.com → your crew → Status tab
SKILL_GAP_PROVIDER=crewai_amp
CREWAI_SKILL_GAP_BASE_URL=https://your-crew-name.crewai.com
CREWAI_SKILL_GAP_BEARER_TOKEN=

# How long to wait for the cloud crew (3 agents can take 1–3 minutes)
CREWAI_AMP_POLL_INTERVAL_SECONDS=2
CREWAI_AMP_POLL_TIMEOUT_SECONDS=300

# --- Local crew fallback (auto-used when AMP lacks resume_text/job_description inputs) ---
# OPENAI_API_KEY=
# OPENAI_MODEL_NAME=gpt-4o-mini

# --- UI dev without any AI ---
# SKILL_GAP_MOCK=true

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated frontend origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://stalwart-macaron-915ce6.netlify.app
